{
  "name": "intelligent-vendor-routing-platform",
  "version": "1.0.0",
  "description": "Production-grade intelligent vendor routing platform with multiple routing strategies, real-time health monitoring, AI-powered configuration, and a React dashboard.",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "db:generate": "npx prisma generate",
    "db:migrate": "npx prisma migrate dev",
    "db:push": "npx prisma db push",
    "db:seed": "node prisma/seed.js",
    "db:studio": "npx prisma studio",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:strategies": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPattern=tests/strategies",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.js\""
  },
  "keywords": [
    "vendor-routing",
    "routing-strategies",
    "health-monitoring",
    "express",
    "prisma",
    "redis"
  ],
  "author": "Anvesh",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.24.0",
    "@prisma/client": "^6.9.0",
    "axios": "^1.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.6.1",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "rate-limit-redis": "^4.2.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.1.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "eslint": "^9.27.0",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "prisma": "^6.9.0"
  },
  "jest": {
    "transform": {},
    "testEnvironment": "node",
    "extensionsToTreatAsEsm": []
  }
}
